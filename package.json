{
  "name": "negotiate-events-field",
  "version": "0.2.0",
  "description": "Negotiate the events header field as proposed in the Events Query Internet-Draft",
  "keywords": [
    "http",
    "events-query",
    "header",
    "field",
    "events",
    "negotiate",
    "negotiation"
  ],
  "author": "Rahul Gupta",
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.com/CxRes/negotiate-events-field.git"
  },
  "type": "module",
  "main": "src/index.js",
  "exports": "./src/index.js",
  "types": "types/index.d.ts",
  "dependencies": {
    "no-try": "^4.0.0",
    "structured-headers": "^2.0.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/compat": "^1.4.0",
    "@eslint/js": "^9.37.0",
    "@types/node": "^24.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/eslint-plugin": "^1.3.16",
    "cspell": "^9.2.1",
    "dedent": "^1.7.0",
    "dts-buddy": "^0.6.2",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^61.0.1",
    "globals": "^16.4.0",
    "headright": "^0.3.0",
    "knip": "^5.64.2",
    "lefthook": "^1.13.6",
    "parse-gitignore": "^2.0.0",
    "prettier": "^3.6.2",
    "prettier-plugin-jsdoc": "^1.3.3",
    "typescript": "<5.9",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "onFail": "error"
    }
  },
  "scripts": {
    "header": "hr --verbose \"**\"",
    "lint": "pnpm run --reporter=append-only --aggregate-output \"/(^lint:.*)/\"",
    "lint:code": "eslint .",
    "lint:format": "prettier ** --check",
    "lint:header": "hr --dry --verbose \"**\"",
    "lint:knip": "knip",
    "lint:packages": "pnpm dedupe --check",
    "lint:spelling": "cspell --gitignore --dot **",
    "prepare": "pnpm run types",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "types": "dts-buddy"
  }
}
